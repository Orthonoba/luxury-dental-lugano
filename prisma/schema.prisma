generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum TreatmentType {
  IMPLANTOLOGY
  ORTHODONTICS
  AESTHETICS
  WHITENING
  PERIODONTICS
  ENDODONTICS
  FACIAL_AESTHETICS
  OTHER
}

enum TreatmentStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum DocumentType {
  BUDGET
  REPORT
  XRAY
  PHOTO
  CONTRACT
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

// ── Auth ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          Role      @default(PATIENT)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient              Patient?
  passwordResetTokens  PasswordResetToken[]

  @@index([email])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ── Patient profile ────────────────────────────────────────────────────────

model Patient {
  id              String    @id @default(cuid())
  userId          String    @unique
  firstName       String
  lastName        String
  phone           String?
  dateOfBirth     DateTime?
  preferredLocale String    @default("it")
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  treatments   Treatment[]
  documents    Document[]
  payments     Payment[]
  appointments PatientAppointment[]

  @@index([userId])
}

// ── Treatments ─────────────────────────────────────────────────────────────

model Treatment {
  id           String          @id @default(cuid())
  patientId    String
  title        String
  type         TreatmentType   @default(OTHER)
  description  String?
  status       TreatmentStatus @default(PLANNED)
  startDate    DateTime?
  estimatedEnd DateTime?
  doctorName   String?
  progress     Int             @default(0)
  totalCost    Decimal?        @db.Decimal(10, 2)
  currency     String          @default("CHF")
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  patient  Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  steps    TreatmentStep[]
  payments Payment[]

  @@index([patientId])
  @@index([status])
}

model TreatmentStep {
  id          String     @id @default(cuid())
  treatmentId String
  title       String
  description String?
  status      StepStatus @default(PENDING)
  scheduledAt DateTime?
  completedAt DateTime?
  order       Int

  treatment Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@index([treatmentId])
}

// ── Appointments ───────────────────────────────────────────────────────────

model PatientAppointment {
  id          String            @id @default(cuid())
  patientId   String
  title       String
  type        String            @default("dental")
  status      AppointmentStatus @default(SCHEDULED)
  doctorName  String?
  scheduledAt DateTime
  duration    Int               @default(30)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([scheduledAt])
}

// ── Documents ──────────────────────────────────────────────────────────────

model Document {
  id          String       @id @default(cuid())
  patientId   String
  type        DocumentType @default(OTHER)
  name        String
  description String?
  filePath    String
  fileSize    Int?
  mimeType    String?
  uploadedBy  String?
  createdAt   DateTime     @default(now())

  patient    Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  accessLogs DocumentAccessLog[]

  @@index([patientId])
}

model DocumentAccessLog {
  id         String   @id @default(cuid())
  documentId String
  userId     String
  accessedAt DateTime @default(now())
  ipAddress  String?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId])
}

// ── Payments ───────────────────────────────────────────────────────────────

model Payment {
  id          String        @id @default(cuid())
  patientId   String
  treatmentId String?
  amount      Decimal       @db.Decimal(10, 2)
  currency    String        @default("CHF")
  status      PaymentStatus @default(PENDING)
  method      String?
  description String?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  patient   Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  treatment Treatment? @relation(fields: [treatmentId], references: [id])

  @@index([patientId])
  @@index([treatmentId])
}

// ── Existing public models (unchanged) ────────────────────────────────────

model PatientLead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?
  createdAt DateTime @default(now())
}

model Appointment {
  id          String   @id @default(cuid())
  patientName String
  email       String
  phone       String
  treatment   String
  date        DateTime
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    String   @default("en")
  createdAt DateTime @default(now())
}

model BookingRequest {
  id          String   @id @default(cuid())
  type        String
  firstName   String
  lastName    String
  email       String
  phone       String
  dateOfBirth String?
  service     String
  notes       String?
  desiredDate DateTime
  desiredTime String
  status      String   @default("pending")
  gdprConsent Boolean
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([desiredDate])
  @@index([type, desiredDate])
}
