generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PatientLead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?
  createdAt DateTime @default(now())
}

model Appointment {
  id          String   @id @default(cuid())
  patientName String
  email       String
  phone       String
  treatment   String
  date        DateTime
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    String   @default("en")
  createdAt DateTime @default(now())
}

model BookingRequest {
  id          String   @id @default(cuid())
  type        String   // "dental" | "facial"
  firstName   String
  lastName    String
  email       String
  phone       String
  dateOfBirth String?
  service     String
  notes       String?
  desiredDate DateTime
  desiredTime String
  status      String   @default("pending")
  gdprConsent Boolean
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([desiredDate])
  @@index([type, desiredDate])
}
