# ──────────────────────────────────────────────────────────────────────────────
# Luxury Dental Lugano — Environment Variables Reference
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── DATABASE (Runtime — NOT baked into the image) ─────────────────────────────
# PostgreSQL connection string (Neon or any compatible provider)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@host:5432/luxurydental?schema=public"

# ── ADMIN / CRM ───────────────────────────────────────────────────────────────
# Email address that receives lead/booking notifications
ADMIN_EMAIL="info@luxurydental-lugano.ch"

# Bearer token for CRM dashboard login (generate a long random string)
ADMIN_TOKEN="change-this-to-a-long-random-secret-token"

# ── EMAIL (Resend) ────────────────────────────────────────────────────────────
# API key from resend.com — leave empty to disable email sending silently
RESEND_API_KEY=""

# ── SANITY CMS (NEXT_PUBLIC_* baked at build time — requires full redeploy) ──
# Project ID from sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=""

# Dataset name (usually "production")
NEXT_PUBLIC_SANITY_DATASET="production"

# API version date (update when schema changes)
NEXT_PUBLIC_SANITY_API_VERSION="2025-05-18"

# ── ANALYTICS ─────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=""

# ── AI CHATBOT ────────────────────────────────────────────────────────────────
# OpenAI API key — required for AI chatbot widget; leave empty to disable
OPENAI_API_KEY=""

# ── NOTES ─────────────────────────────────────────────────────────────────────
# Port: the app starts on 3005 (package.json start script + Dockerfile EXPOSE)
# In Coolify: set the container port to 3005 in the service settings.
#
# DATABASE_URL is a runtime secret — it is NOT baked into the Docker image.
# A placeholder is used at build time (see nixpacks.toml and Dockerfile).
# Run migrations manually before deploying schema changes:
#   DATABASE_URL="<neon-url>" npx prisma migrate deploy
#
# NEXT_PUBLIC_* vars are baked at build time.
# Changing them requires a full image rebuild + redeploy, not just a restart.
