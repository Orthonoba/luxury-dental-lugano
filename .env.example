# ──────────────────────────────────────────────────────────────────────────────
# Luxury Dental Lugano — Environment Variables Reference
# Copy: cp .env.example .env   then fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://luxuser:YOUR_PASSWORD@localhost:5432/luxurydental"

# ── APP ───────────────────────────────────────────────────────────────────────
NODE_ENV="production"
# Public URL used in email links (reset password, verify email)
NEXT_PUBLIC_BASE_URL="https://luxurydental-lugano.ch"

# ── PATIENT PORTAL AUTH (JWT — NOT NextAuth) ──────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET="generate_with_openssl_rand_hex_64"

# ── ADMIN / CRM ───────────────────────────────────────────────────────────────
ADMIN_EMAIL="automatizadental@gmail.com"
# Token for CRM staff login — long random string
ADMIN_TOKEN="generate_long_random_token"

# ── PATIENT DOCUMENTS (AES-256-GCM encryption at rest) ───────────────────────
# Absolute path to folder where encrypted medical documents are stored
DOCUMENTS_PATH="/var/www/luxury-dental-lugano/private-documents"
# Generate: openssl rand -hex 32  (must be exactly 64 hex chars)
DOCUMENTS_ENCRYPTION_KEY="generate_with_openssl_rand_hex_32"

# ── EMAIL (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=""

# ── WHATSAPP BUSINESS CLOUD API (Meta official — never use Baileys) ───────────
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
# Generate: openssl rand -hex 32
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""

# ── CLAUDE AI (for WhatsApp agent "Sofia") ────────────────────────────────────
ANTHROPIC_API_KEY=""

# ── SANITY CMS (baked at build time — full redeploy required to change) ───────
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2025-05-18"

# ── ANALYTICS (optional) ──────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=""

# ── AI CHATBOT WIDGET (optional) ──────────────────────────────────────────────
OPENAI_API_KEY=""

# ──────────────────────────────────────────────────────────────────────────────
# NOTES FOR VPS DEPLOYMENT
# ──────────────────────────────────────────────────────────────────────────────
# 1. App runs on port 3005 (pm2 + package.json start script)
# 2. After git pull + npm install, ALWAYS run:
#      npx prisma migrate deploy
#    before npm run build if schema changed.
# 3. After build with output:'standalone', copy static files:
#      cp -r .next/static .next/standalone/.next/static
#      cp -r public .next/standalone/public
# 4. JWT_SECRET signs patient session cookies — changing it logs out all patients.
# 5. DOCUMENTS_ENCRYPTION_KEY encrypts medical files — NEVER lose this value.
# 6. AUTH_SECRET / NEXTAUTH_SECRET are NOT used — this app uses custom JWT.
# ──────────────────────────────────────────────────────────────────────────────
